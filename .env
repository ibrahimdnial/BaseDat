# .env - Backend Configuration
# Ganti value sesuai dengan setup kamu

# ─────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────

# Option 1: MongoDB Atlas (Cloud)
MONGODB_URI=mongodb+srv://ibrahimdnial_db_user:ZUTKcK94valyAP9Z@cluster0.3vvdmzs.mongodb.net/basedat_db?retryWrites=true&w=majority
# Option 2: MongoDB Local
# MONGODB_URI=mongodb://localhost:27017/basedat_db

# Option 3: PostgreSQL (Alternative)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=basedat_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# ─────────────────────────────────────────────────────────────
# CORS CONFIGURATION
# ─────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://192.168.1.100:5000

# ─────────────────────────────────────────────────────────────
# JWT CONFIGURATION (Optional - untuk security)
# ─────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_here_12345
JWT_EXPIRE=7d

# ─────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=debug
